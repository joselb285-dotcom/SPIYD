    {lat:-28.5,lng:-65.8,frp:42,conf:'nominal',sat:'MODIS',r:'La Rioja'},
    {lat:-35.5,lng:-59.1,frp:30,conf:'nominal',sat:'MODIS',r:'Bs As N'},
