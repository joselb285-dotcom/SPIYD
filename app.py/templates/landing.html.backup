let currentLang='es';
function setLang(l){
  currentLang=l;tLang=l;tIdx=0;tChar=0;tDel=false;
  document.getElementById('html-root').lang=l;
  document.querySelectorAll('.lang-btn').forEach(b=>b.classList.toggle('active',b.textContent.trim().toLowerCase()===l));
  const t=T[l];
  document.querySelectorAll('[data-i18n]').forEach(el=>{const k=el.dataset.i18n;if(t[k]!==undefined)el.textContent=t[k];});
}
</script>
</body>
</html>
