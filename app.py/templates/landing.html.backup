<!DOCTYPE html>
<html lang="es" id="html-root">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SPIYD — Sistema de Prevención de Incendios y Deforestaciones</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css"/>
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css"/>
  <style>
    :root{
      --orange:#f97316;--orange2:#ea580c;--red:#dc2626;
      --green:#16a34a;--blue:#2563eb;--cyan:#0891b2;
      --dark:#0f172a;--dark2:#1e293b;
      --light:#f8fafc;--light2:#f1f5f9;
      --text:#0f172a;--muted:#64748b;--border:#e2e8f0;
      --white:#ffffff;
    }
    *{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:'Segoe UI',system-ui,sans-serif;background:#fff;color:var(--text);overflow-x:hidden}

    /* ── NAVBAR (light) ── */
    .navbar{
      position:fixed;top:0;width:100%;z-index:1000;
      background:rgba(255,255,255,0.92);backdrop-filter:blur(16px);
      border-bottom:1px solid var(--border);padding:10px 0;
      transition:box-shadow .3s;
    }
    .navbar.scrolled{box-shadow:0 2px 20px rgba(0,0,0,0.08)}
    .navbar-brand{
      font-size:1.5rem;font-weight:900;letter-spacing:-1px;text-decoration:none;
      background:linear-gradient(90deg,var(--orange),var(--orange2));
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;
    }
    .nav-link{color:var(--muted)!important;font-weight:500;padding:6px 14px!important;transition:color .2s}
    .nav-link:hover{color:var(--dark)!important}
    .lang-btn{
      background:transparent;border:1px solid var(--border);color:var(--muted);
      border-radius:6px;padding:3px 10px;font-size:11px;font-weight:700;cursor:pointer;
      transition:all .2s;letter-spacing:.5px;
    }
    .lang-btn.active,.lang-btn:hover{background:var(--orange);border-color:var(--orange);color:#fff}
    .btn-nav{
      background:linear-gradient(135deg,var(--orange),var(--orange2));color:#fff!important;
      border-radius:8px;padding:7px 20px!important;font-weight:700;border:none;
      box-shadow:0 2px 12px rgba(249,115,22,.3);transition:all .2s;
    }
    .btn-nav:hover{transform:translateY(-1px);box-shadow:0 4px 20px rgba(249,115,22,.45);color:#fff!important}

    /* ── HERO (dark + fire photo) ── */
    #hero{
      min-height:100vh;display:flex;align-items:center;
      position:relative;overflow:hidden;
      background-image:
        linear-gradient(135deg,rgba(0,0,0,0.72) 0%,rgba(15,0,0,0.55) 50%,rgba(0,0,0,0.78) 100%),
        url('https://images.unsplash.com/photo-1602923668104-8f9e03b5e1b9?w=1920&q=80&auto=format&fit=crop');
      background-color:#1a0400;
      background-size:cover;background-position:center;background-attachment:fixed;
    }
    .hero-content{padding-top:80px;position:relative;z-index:2}
    .hero-tag{
      display:inline-flex;align-items:center;gap:8px;
      background:rgba(249,115,22,0.15);border:1px solid rgba(249,115,22,0.4);
      border-radius:30px;padding:6px 18px;font-size:.8rem;font-weight:600;
      color:#fbbf24;margin-bottom:28px;
    }
    .live-dot{width:7px;height:7px;border-radius:50%;background:#22c55e;
      box-shadow:0 0 0 0 rgba(34,197,94,.6);animation:livePulse 1.5s infinite}
    @keyframes livePulse{0%{box-shadow:0 0 0 0 rgba(34,197,94,.6)}70%{box-shadow:0 0 0 8px rgba(34,197,94,0)}100%{box-shadow:0 0 0 0 rgba(34,197,94,0)}}
    .hero-title{
      font-size:clamp(2.4rem,5.5vw,4.2rem);font-weight:900;color:#fff;
      line-height:1.05;letter-spacing:-1.5px;margin-bottom:16px;
    }
    .hero-title .accent{
      background:linear-gradient(90deg,#fbbf24,#f97316);
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;
    }
    .hero-typed{min-height:2.2rem;font-size:clamp(1rem,2.2vw,1.35rem);color:rgba(255,255,255,.75);margin-bottom:20px}
    #typed-text{color:#fb923c;font-weight:600}
    #typed-cursor{color:#f97316;animation:blink .7s infinite}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:0}}
    .hero-sub{font-size:1.05rem;color:rgba(255,255,255,.65);max-width:540px;line-height:1.8;margin-bottom:36px}
    .btn-fire{
      display:inline-flex;align-items:center;gap:8px;
      background:linear-gradient(135deg,#f97316,#dc2626);color:#fff;
      padding:14px 34px;border-radius:12px;font-size:1rem;font-weight:700;
      text-decoration:none;border:none;cursor:pointer;
      box-shadow:0 4px 28px rgba(249,115,22,.45);transition:all .25s;
    }
    .btn-fire:hover{transform:translateY(-3px);box-shadow:0 8px 40px rgba(249,115,22,.6);color:#fff}
    .btn-outline-light{
      display:inline-flex;align-items:center;gap:8px;
      background:rgba(255,255,255,.08);backdrop-filter:blur(8px);
      border:1px solid rgba(255,255,255,.25);color:#fff;
      padding:14px 30px;border-radius:12px;font-size:1rem;font-weight:600;
      text-decoration:none;transition:all .25s;
    }
    .btn-outline-light:hover{background:rgba(255,255,255,.15);color:#fff}
    .hero-badges{display:flex;flex-wrap:wrap;gap:8px;margin-top:32px}
    .hbadge{
      display:inline-flex;align-items:center;gap:6px;
      background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);
      backdrop-filter:blur(6px);border-radius:8px;
      padding:6px 13px;font-size:.8rem;color:rgba(255,255,255,.75);
    }
    .hbadge i{color:#fb923c;font-size:.8rem}

    /* ── STATS (white) ── */
    #stats{background:#fff;padding:56px 0;border-bottom:1px solid var(--border)}
    .stat-num{font-size:3rem;font-weight:900;color:var(--orange);line-height:1}
    .stat-lbl{color:var(--muted);font-size:.88rem;margin-top:4px}
    .stat-divider{width:1px;background:var(--border)}

    /* ── FEATURES (light gray) ── */
    #features{background:var(--light);padding:96px 0}
    .chip{
      display:inline-block;background:rgba(249,115,22,.1);border:1px solid rgba(249,115,22,.2);
      color:var(--orange);border-radius:30px;padding:4px 16px;
      font-size:.75rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;margin-bottom:16px;
    }
    .section-title{font-size:clamp(1.8rem,3.5vw,2.6rem);font-weight:900;color:var(--dark);margin-bottom:12px;letter-spacing:-.5px}
    .section-sub{color:var(--muted);font-size:1rem;line-height:1.7}
    .feat-card{
      background:#fff;border:1px solid var(--border);border-radius:16px;padding:28px;
      height:100%;transition:transform .3s,box-shadow .3s,border-color .3s;
    }
    .feat-card:hover{transform:translateY(-5px);box-shadow:0 16px 48px rgba(0,0,0,.08);border-color:rgba(249,115,22,.3)}
    .feat-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;margin-bottom:18px}
    .feat-card h5{font-size:.97rem;font-weight:700;color:var(--dark);margin-bottom:8px}
    .feat-card p{color:var(--muted);font-size:.87rem;line-height:1.7;margin:0}

    /* ── DEMO MAP (white + full panel) ── */
    #demo{background:#fff;padding:80px 0}
    #demo-map{height:560px;border-radius:18px;overflow:hidden;border:1px solid var(--border);box-shadow:0 20px 60px rgba(0,0,0,.1);position:relative}
    .map-panel-overlay{
      position:absolute;top:12px;left:12px;z-index:1000;
      background:rgba(10,15,30,0.92);backdrop-filter:blur(12px);
      border:1px solid rgba(255,255,255,.1);border-radius:12px;
      padding:12px 14px;width:210px;color:#e2e8f0;font-size:11px;
      pointer-events:auto;
    }
    .mpo-title{font-size:12px;font-weight:800;color:#fff;margin-bottom:10px;letter-spacing:.3px}
    .mpo-layer{
      display:flex;align-items:center;gap:7px;
      padding:3px 0;cursor:pointer;color:#94a3b8;transition:color .15s;
      border-radius:4px;
    }
    .mpo-layer:hover{color:#e2e8f0}
    .mpo-layer input{accent-color:#f97316;width:12px;height:12px;margin:0;cursor:pointer}
    .mpo-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
    .mpo-divider{border:none;border-top:1px solid rgba(255,255,255,.08);margin:8px 0}
    .mpo-stats{display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-top:4px}
    .mpo-stat{background:rgba(255,255,255,.04);border-radius:6px;padding:5px 7px;text-align:center}
    .mpo-num{font-size:14px;font-weight:800;display:block;color:#fff}
    .mpo-lbl{font-size:9px;color:#64748b;text-transform:uppercase;letter-spacing:.5px}
    .mpo-risk{
      margin-top:8px;text-align:center;padding:5px;border-radius:6px;
      font-size:10px;font-weight:800;letter-spacing:1px;
    }
    .map-legend{display:flex;flex-wrap:wrap;gap:16px;margin-top:20px;padding:16px 20px;background:var(--light);border:1px solid var(--border);border-radius:12px}
    .leg-item{display:flex;align-items:center;gap:6px;font-size:.8rem;color:var(--muted)}
    .leg-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0}
    .leg-line{width:18px;height:3px;border-radius:2px;flex-shrink:0}

    /* ── PRICING (light) ── */
    #pricing{background:var(--light);padding:96px 0}
    .plan-card{
      background:#fff;border:2px solid var(--border);border-radius:20px;
      padding:36px 28px;height:100%;position:relative;transition:all .3s;
    }
    .plan-card:hover{transform:translateY(-6px);box-shadow:0 20px 50px rgba(0,0,0,.08)}
    .plan-card.featured{border-color:var(--orange);box-shadow:0 0 0 4px rgba(249,115,22,.1)}
    .plan-badge{
      position:absolute;top:-14px;left:50%;transform:translateX(-50%);
      background:linear-gradient(135deg,var(--orange),var(--orange2));
      color:#fff;font-size:.7rem;font-weight:800;padding:4px 18px;
      border-radius:30px;letter-spacing:.5px;white-space:nowrap;
    }
    .plan-name{font-size:.72rem;font-weight:700;color:var(--muted);letter-spacing:2px;text-transform:uppercase;margin-bottom:8px}
    .plan-price{font-size:3rem;font-weight:900;color:var(--dark);line-height:1}
    .plan-price small{font-size:.9rem;font-weight:400;color:var(--muted)}
    .plan-features{list-style:none;padding:0;margin:20px 0 26px}
    .plan-features li{padding:8px 0;border-bottom:1px solid var(--border);font-size:.87rem;color:var(--muted);display:flex;align-items:center;gap:9px}
    .plan-features li i.fa-check{color:var(--green)}
    .plan-features li.off i{color:#cbd5e1}
    .plan-features li.off{color:#cbd5e1}
    .btn-primary-orange{
      display:block;width:100%;text-align:center;padding:13px;border-radius:10px;
      background:linear-gradient(135deg,var(--orange),var(--orange2));color:#fff;
      font-weight:700;text-decoration:none;border:none;cursor:pointer;
      box-shadow:0 4px 16px rgba(249,115,22,.3);transition:all .2s;
    }
    .btn-primary-orange:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(249,115,22,.45);color:#fff}
    .btn-outline-orange{
      display:block;width:100%;text-align:center;padding:13px;border-radius:10px;
      background:transparent;color:var(--orange);border:2px solid var(--border);
      font-weight:700;text-decoration:none;transition:all .2s;
    }
    .btn-outline-orange:hover{border-color:var(--orange);background:rgba(249,115,22,.05);color:var(--orange)}

    /* ── CTA (dark + fire photo) ── */
    #cta{
      background-image:
        linear-gradient(135deg,rgba(0,0,0,0.78),rgba(30,10,0,0.82)),
        url('https://images.unsplash.com/photo-1568283096533-078a27b31520?w=1920&q=80&auto=format&fit=crop');
      background-color:#1a0800;background-size:cover;background-position:center;
      padding:100px 0;text-align:center;
    }
    .cta-title{font-size:clamp(2rem,4vw,3rem);font-weight:900;color:#fff;letter-spacing:-.5px;margin-bottom:16px}
    .cta-title .accent{
      background:linear-gradient(90deg,#fbbf24,#f97316);
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;
    }
    .cta-sub{color:rgba(255,255,255,.65);font-size:1.05rem;margin-bottom:36px}

    /* ── FOOTER (dark) ── */
    footer{background:var(--dark);padding:56px 0 24px}
    .footer-brand{
      font-size:1.4rem;font-weight:900;
      background:linear-gradient(90deg,var(--orange),#fbbf24);
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;
    }
    .footer-link{color:#475569;text-decoration:none;font-size:.87rem;display:block;margin-bottom:8px;transition:color .2s}
    .footer-link:hover{color:#94a3b8}
    .footer-divider{border-color:#1e293b;margin:32px 0 20px}
    .footer-bottom{color:#334155;font-size:.8rem}

    /* ── SCROLL REVEAL ── */
    .reveal{opacity:0;transform:translateY(24px);transition:opacity .7s ease,transform .7s ease}
    .reveal.visible{opacity:1;transform:none}
    .reveal-d1{transition-delay:.1s}.reveal-d2{transition-delay:.2s}.reveal-d3{transition-delay:.3s}
    .reveal-d4{transition-delay:.4s}.reveal-d5{transition-delay:.5s}

    /* leaflet dark override for demo map */
    #demo-map .leaflet-tile-pane{filter:brightness(.85) saturate(.8)}
    #demo-map .leaflet-control-zoom a{background:#161b22!important;color:#e2e8f0!important;border-color:#334155!important}
  </style>
</head>
<body>

<!-- ── NAVBAR ── -->
<nav class="navbar" id="navbar">
  <div class="container d-flex align-items-center justify-content-between">
    <a class="navbar-brand" href="#">🔥 SPIYD</a>
    <div class="d-flex align-items-center gap-3">
      <div class="d-none d-md-flex">
        <a class="nav-link" href="#features" data-i18n="nav_feat">Características</a>
        <a class="nav-link" href="#demo" data-i18n="nav_demo">Demo</a>
        <a class="nav-link" href="#pricing" data-i18n="nav_price">Precios</a>
      </div>
      <div class="d-flex gap-1">
        <button class="lang-btn active" onclick="setLang('es')">ES</button>
        <button class="lang-btn" onclick="setLang('en')">EN</button>
        <button class="lang-btn" onclick="setLang('pt')">PT</button>
      </div>
      <a href="/login" class="nav-link btn-nav" data-i18n="nav_login">Ingresar</a>
    </div>
  </div>
</nav>

<!-- ── HERO ── -->
<section id="hero">
  <div class="container hero-content">
    <div class="row align-items-center">
      <div class="col-lg-7">
        <div class="hero-tag">
          <span class="live-dot"></span>
          <span data-i18n="hero_tag">Sistema activo — Monitoreo en tiempo real</span>
        </div>
        <h1 class="hero-title">
          <span class="accent">SPIYD</span><br>
          <span data-i18n="hero_h1">Prevención de Incendios</span><br>
          <span data-i18n="hero_h2">y Deforestaciones</span>
        </h1>
        <div class="hero-typed">
          <span data-i18n="hero_typed_pre">Para </span><span id="typed-text"></span><span id="typed-cursor">|</span>
        </div>
        <p class="hero-sub" data-i18n="hero_sub">
          Monitoreo satelital NASA + INPE + GOES-16 en tiempo real, alertas automáticas por Telegram y análisis con IA para proteger los bosques de América del Sur.
        </p>
        <div class="d-flex flex-wrap gap-3">
          <a href="/login" class="btn-fire" data-i18n="hero_cta1">
            <i class="fas fa-shield-halved"></i> Acceder al Sistema
          </a>
          <a href="#demo" class="btn-outline-light" data-i18n="hero_cta2">
            <i class="fas fa-map"></i> Ver Demo
          </a>
        </div>
        <div class="hero-badges">
          <span class="hbadge"><i class="fas fa-satellite"></i> NASA FIRMS</span>
          <span class="hbadge"><i class="fas fa-satellite-dish"></i> GOES-16 / INPE</span>
          <span class="hbadge"><i class="fas fa-wind"></i><span data-i18n="badge_wind">Viento Open-Meteo</span></span>
          <span class="hbadge"><i class="fas fa-cloud-bolt"></i> SMN Argentina</span>
          <span class="hbadge"><i class="fas fa-robot"></i> Claude AI</span>
        </div>
      </div>
      <div class="col-lg-5 d-none d-lg-flex justify-content-end">
        <!-- Stats box floating -->
        <div style="background:rgba(10,15,30,0.85);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:28px;min-width:260px">
          <div style="font-size:.7rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:#64748b;margin-bottom:16px">Estado del sistema</div>
          <div style="display:flex;flex-direction:column;gap:12px">
            <div style="display:flex;justify-content:space-between;align-items:center">
              <div style="display:flex;align-items:center;gap:8px;font-size:.85rem;color:#94a3b8"><span style="width:8px;height:8px;border-radius:50%;background:#ef4444;display:inline-block;animation:livePulse 1.5s infinite"></span>Focos NASA activos</div>
              <strong style="color:#fff">1.243</strong>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center">
              <div style="display:flex;align-items:center;gap:8px;font-size:.85rem;color:#94a3b8"><span style="width:8px;height:8px;border-radius:50%;background:#f97316;display:inline-block;animation:livePulse 2s infinite"></span>Focos INPE / GOES</div>
              <strong style="color:#fff">387</strong>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center">
              <div style="display:flex;align-items:center;gap:8px;font-size:.85rem;color:#94a3b8"><span style="width:8px;height:8px;border-radius:50%;background:#fbbf24;display:inline-block"></span>Alertas SMN activas</div>
              <strong style="color:#fff">14</strong>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center">
              <div style="display:flex;align-items:center;gap:8px;font-size:.85rem;color:#94a3b8"><span style="width:8px;height:8px;border-radius:50%;background:#ab47bc;display:inline-block"></span>FWI máximo</div>
              <strong style="color:#f97316;font-size:1.1rem">68 — Extremo</strong>
            </div>
            <div style="display:flex;justify-content:space-between;align-items:center">
              <div style="display:flex;align-items:center;gap:8px;font-size:.85rem;color:#94a3b8"><span style="width:8px;height:8px;border-radius:50%;background:#ef4444;display:inline-block;animation:livePulse 1s infinite"></span>Zonas 30-30-30</div>
              <strong style="color:#ef4444">3 activas</strong>
            </div>
          </div>
          <div style="margin-top:16px;padding-top:14px;border-top:1px solid rgba(255,255,255,.07);font-size:.7rem;color:#475569">
            <i class="fas fa-clock me-1"></i><span data-i18n="hero_updated">Actualizado hace 4 min</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── STATS ── -->
<section id="stats">
  <div class="container">
    <div class="row g-4 align-items-center">
      <div class="col-6 col-md-3 text-center reveal">
        <div class="stat-num"><span data-target="24">0</span>/<span data-target="7">0</span></div>
        <div class="stat-lbl" data-i18n="stat1">Monitoreo continuo</div>
      </div>
      <div class="col-6 col-md-3 text-center reveal reveal-d1">
        <div class="stat-num">+<span data-target="1500">0</span></div>
        <div class="stat-lbl" data-i18n="stat2">Focos procesados</div>
      </div>
      <div class="col-6 col-md-3 text-center reveal reveal-d2">
        <div class="stat-num"><span data-target="98">0</span>%</div>
        <div class="stat-lbl" data-i18n="stat3">Precisión NASA VIIRS</div>
      </div>
      <div class="col-6 col-md-3 text-center reveal reveal-d3">
        <div class="stat-num"><span data-target="10">0</span> min</div>
        <div class="stat-lbl" data-i18n="stat4">Latencia de datos</div>
      </div>
    </div>
  </div>
</section>

<!-- ── FEATURES ── -->
<section id="features">
  <div class="container">
    <div class="text-center mb-5 reveal">
      <div class="chip" data-i18n="feat_chip">Tecnología</div>
      <h2 class="section-title" data-i18n="feat_title">Todo en un solo sistema</h2>
      <p class="section-sub mx-auto" style="max-width:560px" data-i18n="feat_sub">Capas de datos satelitales, meteorológicos e hidrográficos integrados en tiempo real</p>
    </div>
    <div class="row g-4">
      <div class="col-md-6 col-lg-4 reveal reveal-d1">
        <div class="feat-card">
          <div class="feat-icon" style="background:#fef3c7"><i class="fas fa-satellite" style="color:#d97706"></i></div>
          <h5 data-i18n="f1t">NASA FIRMS — VIIRS / MODIS</h5>
          <p data-i18n="f1d">Focos de calor de los satélites VIIRS (NOAA-20/21, Suomi NPP) y MODIS con actualización cada 10 minutos. Cobertura completa de Argentina y América del Sur.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4 reveal reveal-d2">
        <div class="feat-card">
          <div class="feat-icon" style="background:#fee2e2"><i class="fas fa-satellite-dish" style="color:#dc2626"></i></div>
          <h5 data-i18n="f2t">GOES-16 + INPE en Tiempo Real</h5>
          <p data-i18n="f2d">Detección de incendios GOES-16 con badge LIVE y datos INPE/METOP para Brasil y países limítrofes. Sincronización continua con actualización automática.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4 reveal reveal-d3">
        <div class="feat-card">
          <div class="feat-icon" style="background:#ede9fe"><i class="fas fa-fire" style="color:#7c3aed"></i></div>
          <h5 data-i18n="f3t">Índice FWI + Regla 30-30-30</h5>
          <p data-i18n="f3d">Cálculo del Fire Weather Index canadiense adaptado al hemisferio sur y detección automática de zonas donde se cumple la condición 30-30-30 de riesgo extremo.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4 reveal reveal-d1">
        <div class="feat-card">
          <div class="feat-icon" style="background:#dbeafe"><i class="fas fa-wind" style="color:#2563eb"></i></div>
          <h5 data-i18n="f4t">Viento y Clima Open-Meteo + SMN</h5>
          <p data-i18n="f4d">Animación de viento en tiempo real, grilla climática completa (temperatura, humedad, precipitación) y alertas CAP del Servicio Meteorológico Nacional.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4 reveal reveal-d2">
        <div class="feat-card">
          <div class="feat-icon" style="background:#d1fae5"><i class="fas fa-water" style="color:#059669"></i></div>
          <h5 data-i18n="f5t">Agua, Vegetación y Topografía</h5>
          <p data-i18n="f5d">Fuentes de agua (embalses, ríos, lagunas) vía OpenStreetMap, índice de vegetación NDVI, relieve topográfico y caminos de acceso para logística de emergencia.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4 reveal reveal-d3">
        <div class="feat-card">
          <div class="feat-icon" style="background:#f3e8ff"><i class="fas fa-robot" style="color:#9333ea"></i></div>
          <h5 data-i18n="f6t">Análisis IA + Alertas Telegram</h5>
          <p data-i18n="f6d">Análisis completo de situación con Claude AI de Anthropic y alertas automáticas por Telegram cuando se detectan nuevos focos con nivel de riesgo elevado.</p>
        </div>
      </div>
    </div>
  </div>
</section>

