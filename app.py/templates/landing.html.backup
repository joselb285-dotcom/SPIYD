    {lat:-41.5,lng:-71.5,type:'Lago',name:'Nahuel Huapi',vol:'2100 hm³'},
    {lat:-29.1,lng:-59.2,type:'Río',name:'Paraná'},
    {lat:-26.8,lng:-58.7,type:'Río',name:'Paraguay'},
  ],
  veg:[
    {lat:-26.2,lng:-53.4,ndvi:.82,type:'Selva Misionera'},
    {lat:-27.5,lng:-56.5,ndvi:.68,type:'Bosque Chaqueño'},
    {lat:-37.5,lng:-71.0,ndvi:.71,type:'Bosque Andino'},
    {lat:-31.5,lng:-64.0,ndvi:.45,type:'Monte Serrano'},
    {lat:-23.0,lng:-63.5,ndvi:.55,type:'Yungas'},
  ],
