    {lat:-25.5,lng:-61.5,frp:52,conf:'nominal',sat:'MODIS',r:'Chaco W'},
  ],
  inpe:[
    {lat:-25.5,lng:-54.6,frp:95,sat:'GOES-16',r:'Misiones NE'},
    {lat:-27.1,lng:-56.3,frp:72,sat:'METOP',r:'Corrientes NE'},
