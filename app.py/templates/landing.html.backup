    {lat:-26.8,lng:-54.2,frp:130,sat:'GOES-16',r:'Misiones S'},
    {lat:-24.1,lng:-66.0,frp:78,sat:'METOP',r:'Puna'},
  ],
  goes:[
    {lat:-24.5,lng:-65.1,r:'Salta RT',conf:95},
    {lat:-26.5,lng:-53.2,r:'Misiones RT',conf:88},
    {lat:-31.2,lng:-64.0,r:'Córdoba RT',conf:91},
  ],
  smn:[
    {lat:-31.5,lng:-63.0,radius:160000,level:'naranja',title:'Alerta calor extremo',temp:42,wind:25},
    {lat:-24.5,lng:-65.0,radius:120000,level:'rojo',title:'Alerta roja — ola de calor',temp:46,wind:35},
    {lat:-34.8,lng:-59.5,radius:200000,level:'amarillo',title:'Tormentas severas',temp:32,wind:55},
    {lat:-38.0,lng:-68.0,radius:140000,level:'naranja',title:'Vientos fuertes',temp:35,wind:65},
  ],
  agua:[
    {lat:-31.5,lng:-64.5,type:'Embalse',name:'Los Molinos',vol:'300 hm³'},
    {lat:-33.7,lng:-69.0,type:'Laguna',name:'Potrerillos',vol:'90 hm³'},
