    {lat:-31.4,lng:-64.2,radius:60000,temp:41,viento:35,humedad:22},
    {lat:-26.2,lng:-53.4,radius:50000,temp:40,viento:32,humedad:25},
  ]
};

/* ═══ MAPA ═══ */
const map = L.map('demo-map',{scrollWheelZoom:false,zoomControl:true,attributionControl:false})
            .setView([-34,-64],5);

L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{maxZoom:19,subdomains:'abcd'}).addTo(map);
L.control.attribution({position:'bottomright',prefix:''}).addTo(map)
  .setPrefix('© SPIYD Demo · CartoDB · Datos simulados');

/* ── helpers ── */
const fwiColor=l=>({extremo:'#7c3aed',muy_alto:'#ef4444',alto:'#f97316',moderado:'#f59e0b',bajo:'#22c55e'}[l]||'#94a3b8');
const smnColor=l=>({rojo:'#ef4444',naranja:'#f97316',amarillo:'#f59e0b',verde:'#22c55e'}[l]||'#94a3b8');
const popStyle='font-size:12px;min-width:160px';
function popHdr(t,c){return `<div style="${popStyle}"><b style="color:${c}">${t}</b>`}

/* ── Capas ── */
const layers={};

// NASA — cluster
const nasaCluster=L.markerClusterGroup({maxClusterRadius:40,disableClusteringAtZoom:8});
D.nasa.forEach(f=>{
  const c=f.conf==='high'?'#ef4444':'#fca5a5';
  const r=f.frp>100?11:f.frp>60?9:7;
  nasaCluster.addLayer(L.circleMarker([f.lat,f.lng],{radius:r,color:c,fillColor:c,fillOpacity:.8,weight:2})
    .bindPopup(`${popHdr('🛰 NASA FIRMS',c)}<br>Región: ${f.r}<br>Satélite: ${f.sat}<br>FRP: ${f.frp} MW<br>Confianza: ${f.conf}</div>`));
});
layers.nasa=nasaCluster;map.addLayer(nasaCluster);

// INPE
const inpeGrp=L.layerGroup();
D.inpe.forEach(f=>{
  inpeGrp.addLayer(L.circleMarker([f.lat,f.lng],{radius:8,color:'#f97316',fillColor:'#f97316',fillOpacity:.7,weight:2,dashArray:'4 2'})
    .bindPopup(`${popHdr('🛰 INPE/METOP','#f97316')}<br>Región: ${f.r}<br>Satélite: ${f.sat}<br>FRP: ${f.frp} MW</div>`));
});
layers.inpe=inpeGrp;map.addLayer(inpeGrp);

// GOES RT (pulsing)
const goesGrp=L.layerGroup();
D.goes.forEach(f=>{
  const iconHtml=`<div style="width:20px;height:20px;border-radius:50%;background:#ff1744;opacity:.85;box-shadow:0 0 0 4px rgba(255,23,68,.35);animation:livePulse 1s infinite"></div>`;
  goesGrp.addLayer(L.marker([f.lat,f.lng],{icon:L.divIcon({html:iconHtml,iconSize:[20,20],iconAnchor:[10,10],className:''})})
    .bindPopup(`${popHdr('🔴 GOES-16 LIVE','#ff1744')}<br>Región: ${f.r}<br>Confianza: ${f.conf}%<br><b style="color:#ff1744">● TIEMPO REAL</b></div>`));
});
layers.goes=goesGrp;map.addLayer(goesGrp);

// SMN alertas
const smnGrp=L.layerGroup();
D.smn.forEach(a=>{
  const c=smnColor(a.level);
  smnGrp.addLayer(L.circle([a.lat,a.lng],{radius:a.radius,color:c,fillColor:c,fillOpacity:.12,weight:2,dashArray:'6 4'})
    .bindPopup(`${popHdr('📡 Alerta SMN — '+a.level.toUpperCase(),c)}<br>${a.title}<br>Temp máx: ${a.temp}°C · Viento: ${a.wind} km/h</div>`));
});
layers.smn=smnGrp;map.addLayer(smnGrp);

// Viento — flechas SVG
const windGrp=L.layerGroup();
D.wind.forEach(w=>{
  const c=w.spd>50?'#ef4444':w.spd>35?'#f97316':w.spd>20?'#60a5fa':'#94a3b8';
  const sz=w.spd>50?22:w.spd>35?19:16;
  const icon=L.divIcon({
    html:`<div style="transform:rotate(${w.dir}deg);color:${c};font-size:${sz}px;line-height:1;filter:drop-shadow(0 0 3px rgba(0,0,0,.8))">↑</div>`,
    iconSize:[sz,sz],iconAnchor:[sz/2,sz/2],className:''
  });
  windGrp.addLayer(L.marker([w.lat,w.lng],{icon})
    .bindPopup(`${popHdr('💨 Viento','#60a5fa')}<br>Velocidad: ${w.spd} km/h<br>Dirección: ${w.dir}°</div>`));
});
layers.wind=windGrp;map.addLayer(windGrp);

// Agua
const aguaGrp=L.layerGroup();
D.agua.forEach(a=>{
  const icon=L.divIcon({
    html:`<div style="background:#0891b2;width:22px;height:22px;border-radius:50%;display:flex;align-items:center;justify-content:center;border:2px solid #22d3ee;box-shadow:0 2px 8px rgba(0,0,0,.5);font-size:11px">💧</div>`,
    iconSize:[22,22],iconAnchor:[11,11],className:''
  });
  aguaGrp.addLayer(L.marker([a.lat,a.lng],{icon})
    .bindPopup(`${popHdr('💧 '+a.type,'#22d3ee')}<br>${a.name}${a.vol?'<br>Volumen: '+a.vol:''}</div>`));
});
layers.agua=aguaGrp;map.addLayer(aguaGrp);

// Vegetación NDVI
const vegGrp=L.layerGroup();
D.veg.forEach(v=>{
  const g=Math.floor(v.ndvi*200+55);
  const c=`rgb(0,${g},40)`;
  vegGrp.addLayer(L.circleMarker([v.lat,v.lng],{radius:10,color:'#4ade80',fillColor:c,fillOpacity:.75,weight:2})
    .bindPopup(`${popHdr('🌿 Vegetación','#4ade80')}<br>${v.type}<br>NDVI: ${v.ndvi} (${v.ndvi>.7?'Alta':'Media'} densidad)</div>`));
});
layers.veg=vegGrp;map.addLayer(vegGrp);

// FWI — Índice de peligro
const fwiGrp=L.layerGroup();
D.fwi.forEach(f=>{
  const c=fwiColor(f.level);
  const labels={extremo:'EXTREMO',muy_alto:'MUY ALTO',alto:'ALTO',moderado:'MODERADO',bajo:'BAJO'};
  const icon=L.divIcon({
    html:`<div style="background:${c};border-radius:6px;padding:2px 5px;font-size:9px;font-weight:800;color:#fff;border:1px solid rgba(255,255,255,.3);box-shadow:0 2px 6px rgba(0,0,0,.4);white-space:nowrap">FWI ${f.fwi}</div>`,
    iconSize:[52,18],iconAnchor:[26,9],className:''
  });
  fwiGrp.addLayer(L.marker([f.lat,f.lng],{icon})
    .bindPopup(`${popHdr('🔥 FWI — '+labels[f.level],c)}<br>Índice: ${f.fwi}<br>Nivel: ${labels[f.level]}</div>`));
});
layers.fwi=fwiGrp;map.addLayer(fwiGrp);

// Radar SMN/INVAP
const radarGrp=L.layerGroup();
D.radar.forEach(r=>{
  radarGrp.addLayer(L.circle([r.lat,r.lng],{radius:r.range*1000,color:'#38bdf8',fillColor:'#0ea5e9',fillOpacity:.04,weight:1,dashArray:'5 5'}));
  const icon=L.divIcon({
    html:`<div style="background:#0c4a6e;width:16px;height:16px;border-radius:3px;border:2px solid #38bdf8;box-shadow:0 0 8px rgba(56,189,248,.5)"></div>`,
    iconSize:[16,16],iconAnchor:[8,8],className:''
  });
  radarGrp.addLayer(L.marker([r.lat,r.lng],{icon})
    .bindPopup(`${popHdr('📡 Radar '+r.name,'#38bdf8')}<br>Alcance: ${r.range} km<br>SMN/INVAP</div>`));
});
layers.radar=radarGrp;map.addLayer(radarGrp);

// Zonas 30-30-30
const zonasGrp=L.layerGroup();
D.zonas.forEach(z=>{
  zonasGrp.addLayer(L.circle([z.lat,z.lng],{radius:z.radius,color:'#ff5722',fillColor:'#ff5722',fillOpacity:.1,weight:3,dashArray:'8 4'})
    .bindPopup(`${popHdr('⚡ ZONA 30-30-30','#ff5722')}<br>Temp: ${z.temp}°C (&gt;30°C ✓)<br>Viento: ${z.viento} km/h (&gt;30 ✓)<br>Humedad: ${z.humedad}% (&lt;30% ✓)<br><b style="color:#ff5722">RIESGO EXTREMO</b></div>`));
});
layers.zonas=zonasGrp;map.addLayer(zonasGrp);

function toggleLayer(name,on){on?map.addLayer(layers[name]):map.removeLayer(layers[name])}

/* ═══ TYPED TEXT ═══ */
const phrases={
  es:['proteger los bosques','prevenir incendios forestales','detectar deforestación en tiempo real','monitorear con satélites NASA y GOES-16'],
  en:['protect forests','prevent wildfires','detect deforestation in real time','monitor with NASA and GOES-16 satellites'],
  pt:['proteger as florestas','prevenir incêndios florestais','detectar desmatamento em tempo real','monitorar com satélites NASA e GOES-16']
};
let tLang='es',tIdx=0,tChar=0,tDel=false;
const tEl=document.getElementById('typed-text');
function typeStep(){
  const ph=phrases[tLang][tIdx];
  tDel?(tEl.textContent=ph.substring(0,--tChar)):(tEl.textContent=ph.substring(0,++tChar));
  if(!tDel&&tChar===ph.length){tDel=true;setTimeout(typeStep,2200);return}
  if(tDel&&tChar===0){tDel=false;tIdx=(tIdx+1)%phrases[tLang].length}
  setTimeout(typeStep,tDel?42:72);
}
typeStep();

/* ═══ NAVBAR SCROLL ═══ */
window.addEventListener('scroll',()=>document.getElementById('navbar').classList.toggle('scrolled',scrollY>60),{passive:true});

/* ═══ SCROLL REVEAL ═══ */
new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible')}),{threshold:.12,rootMargin:'0px 0px -30px 0px'})
  .observe.call(new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible')}),{threshold:.12,rootMargin:'0px 0px -30px 0px'}),document.body);

(()=>{
  const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible')}),{threshold:.1,rootMargin:'0px 0px -30px 0px'});
  document.querySelectorAll('.reveal').forEach(el=>obs.observe(el));
})();

/* ═══ ANIMATED COUNTERS ═══ */
function animNum(el,target,dur=1600){
  const s=performance.now();
  (function t(now){
    const p=Math.min((now-s)/dur,1),e=1-Math.pow(1-p,3);
    el.textContent=Math.round(e*target);
    if(p<1)requestAnimationFrame(t);
  })(s);
}
new IntersectionObserver(es=>es.forEach(e=>{
  if(e.isIntersecting){
    e.target.querySelectorAll('[data-target]').forEach(el=>animNum(el,+el.dataset.target));
    e.currentTarget.unobserve?e.currentTarget.unobserve(e.target):null;
  }
}),{threshold:.3}).observe?
(()=>{
  const o=new IntersectionObserver(es=>es.forEach(e=>{
    if(e.isIntersecting){e.target.querySelectorAll('[data-target]').forEach(el=>animNum(el,+el.dataset.target));o.unobserve(e.target);}
  }),{threshold:.3});
  document.querySelectorAll('#stats .col-6').forEach(el=>o.observe(el));
})():null;

(()=>{
  const o=new IntersectionObserver(es=>es.forEach(e=>{
    if(e.isIntersecting){e.target.querySelectorAll('[data-target]').forEach(el=>animNum(el,+el.dataset.target));o.unobserve(e.target);}
  }),{threshold:.3});
  document.querySelectorAll('#stats .col-6').forEach(el=>o.observe(el));
})();

